# This file intentionally left empty.
# Electron mirror is configured in scripts/fetch-electron.cjs and the
# postinstall extraction flow; see scripts/postinstall.cjs for details.
#
# Previously used: electron_mirror=https://npmmirror.com/mirrors/electron/
